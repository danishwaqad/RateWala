# Copy to .env.local and fill in your Supabase project values (never commit .env.local)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Admin panel — only this email can access /admin
ADMIN_EMAIL=you@example.com

# Server-only: Supabase service role for admin updates (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Site URL for SEO + reminder links
NEXT_PUBLIC_SITE_URL=https://ratewala.vercel.app

# Optional: email reminders via Resend (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=RateWala <noreply@yourdomain.com>

# Optional: protect cron endpoint GET /api/cron/stale-reminders
CRON_SECRET=your_random_secret
